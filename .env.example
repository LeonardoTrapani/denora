# WorkOS AuthKit server credentials.
WORKOS_API_KEY=sk_test_replace_with_workos_api_key
WORKOS_CLIENT_ID=client_replace_with_workos_client_id
# Secret used by WorkOS to seal session cookies (use a long random value, >= 32 chars).
WORKOS_COOKIE_PASSWORD=replace_with_a_long_random_secret_at_least_32_chars

# Optional local telemetry labels. Axiom OTLP token/endpoints are provisioned
# by Alchemy and bound to the local Worker automatically.
# DENORA_SERVICE_INSTANCE_ID=local-main
# DENORA_GIT_BRANCH=main
# DENORA_GIT_SHA=replace_with_current_git_sha
