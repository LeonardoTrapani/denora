WORKOS_API_KEY=sk_test_your_staging_workos_api_key
WORKOS_CLIENT_ID=client_your_staging_workos_client_id
WORKOS_COOKIE_PASSWORD=0123456789abcdef0123456789abcdef
CSRF_SECRET=replace_with_a_non_empty_staging_secret

# Browser origins allowed to call staging with credentials.
# Include Expo web dev if testing mobile locally against staging.
DENORA_WEB_ORIGINS=https://denora-web-staging.example.workers.dev,http://localhost:8081
DENORA_APP_REDIRECT_SCHEMES=denora

# Optional. Leave empty unless testing cookies across staging subdomains.
DENORA_COOKIE_DOMAIN=
