# Better Auth — secret used to derive signing keys (use a long random value, >= 32 chars).
BETTER_AUTH_SECRET=replace_with_a_long_random_secret_at_least_32_chars
# Public origin Better Auth serves from (used for cookies + as a trusted origin).
BETTER_AUTH_URL=http://localhost:1337

# Local browser origins allowed for CORS + as Better Auth trusted origins.
# Empty or omitted uses the same local defaults.
DENORA_WEB_ORIGINS=http://localhost:3000,http://localhost:1338,http://localhost:8081

# Google OAuth credentials for Better Auth social sign-in.
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret
