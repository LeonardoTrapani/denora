# WorkOS AuthKit server credentials.
WORKOS_API_KEY=sk_test_replace_with_workos_api_key
WORKOS_CLIENT_ID=client_replace_with_workos_client_id
# Secret used by WorkOS to seal session cookies (use a long random value, >= 32 chars).
WORKOS_COOKIE_PASSWORD=replace_with_a_long_random_secret_at_least_32_chars
# Public origin this API serves from. WorkOS redirects back to /api/auth/callback here.
WORKOS_REDIRECT_BASE_URL=http://localhost:1337

# Local browser origins allowed for CORS and safe auth return redirects.
# Empty or omitted uses the same local defaults.
DENORA_WEB_ORIGINS=http://localhost:3000,http://localhost:1338,http://localhost:8081
