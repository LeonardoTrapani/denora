# Deployed dev uses dev.denora.me and api.dev.denora.me.
# Use a separate WorkOS client configured with:
# Redirect URI: https://api.dev.denora.me/api/auth/callback
WORKOS_API_KEY=sk_test_replace_with_dev_workos_api_key
WORKOS_CLIENT_ID=client_replace_with_dev_workos_client_id
WORKOS_COOKIE_PASSWORD=replace_with_a_long_random_secret_at_least_32_chars
