{
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@denora/ui/*": ["../ui/src/*"],
      "~/*": ["./src/*"]
    },
    "target": "ES2024",
    "types": ["vite/client", "node"],
    "verbatimModuleSyntax": false
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"]
}
