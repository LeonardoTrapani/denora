{
  "name": "@denora/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./Client": {
      "types": "./src/Client.ts",
      "bun": "./src/Client.ts",
      "import": "./src/Client.ts",
      "default": "./src/Client.ts"
    },
    "./client-api": {
      "types": "./src/ClientApi.ts",
      "bun": "./src/ClientApi.ts",
      "import": "./src/ClientApi.ts",
      "default": "./src/ClientApi.ts"
    },
    "./http/Api": {
      "types": "./src/http/Api.ts",
      "bun": "./src/http/Api.ts",
      "import": "./src/http/Api.ts",
      "default": "./src/http/Api.ts"
    },
    "./http-api": {
      "types": "./src/http/PublicApi.ts",
      "bun": "./src/http/PublicApi.ts",
      "import": "./src/http/PublicApi.ts",
      "default": "./src/http/PublicApi.ts"
    },
    "./persistence/AlchemyDb": {
      "types": "./src/persistence/AlchemyDb.ts",
      "bun": "./src/persistence/AlchemyDb.ts",
      "import": "./src/persistence/AlchemyDb.ts",
      "default": "./src/persistence/AlchemyDb.ts"
    },
    "./server/Resource": {
      "types": "./src/server/Resource.ts",
      "bun": "./src/server/Resource.ts",
      "import": "./src/server/Resource.ts",
      "default": "./src/server/Resource.ts"
    }
  },
  "scripts": {
    "auth:schema": "better-auth generate --config auth.ts --output src/persistence/schema/auth.ts --yes && bun scripts/strip-auth-relations.ts",
    "build": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test-types": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/sql-pg": "^4.0.0-beta.83",
    "alchemy": "^2.0.0-beta.55",
    "better-auth": "^1.6.18",
    "drizzle-orm": "1.0.0-rc.1",
    "effect": "^4.0.0-beta.83",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@effect/platform-node": "^4.0.0-beta.83",
    "@effect/vitest": "4.0.0-beta.83",
    "@testcontainers/postgresql": "^12.0.2",
    "vitest": "^4.1.8"
  }
}
