# Production uses denora.me and api.denora.me.
# Use a separate WorkOS client configured with:
# Redirect URI: https://api.denora.me/api/auth/callback
WORKOS_API_KEY=sk_live_replace_with_production_workos_api_key
WORKOS_CLIENT_ID=client_replace_with_production_workos_client_id
WORKOS_COOKIE_PASSWORD=replace_with_a_long_random_secret_at_least_32_chars
